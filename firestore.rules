// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: leaderboards/{levelId}/scores
// Document ID: {userId}
// Fields:
//   - userId: string (required, immutable) - The UID of the user
//   - userName: string (required, max 50 chars) - The display name
//   - score: number (required, positive) - The time in milliseconds
//   - timestamp: timestamp (required) - When the score was achieved
//
// Collection: users
// Document ID: {userId}
// Fields:
//   - displayName: string (required, max 50 chars)
//   - photoURL: string (optional, valid URL)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "Tharderer@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidScore(data) {
      return data.keys().hasAll(['userId', 'userName', 'score', 'timestamp']) &&
             data.keys().hasOnly(['userId', 'userName', 'score', 'timestamp']) &&
             data.userId == request.auth.uid &&
             data.userName is string && data.userName.size() <= 50 &&
             data.score is number && data.score > 0 &&
             data.timestamp is timestamp;
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['displayName']) &&
             data.keys().hasOnly(['displayName', 'photoURL', 'role']) &&
             data.displayName is string && data.displayName.size() <= 50 &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() <= 500)) &&
             (!('role' in data) || isAdmin()); // Only admins can set roles
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if true;
      allow create, update: if isOwner(userId) && isValidUserProfile(request.resource.data);
      allow delete: if isAdmin();
    }

    match /leaderboards/{levelId}/scores/{userId} {
      // Allow anyone to read the leaderboard (top 10)
      allow read: if true;
      
      // Only the owner can create or update their own score
      // We also ensure they can't "hack" the score by making it negative or missing fields
      allow create, update: if isOwner(userId) && isValidScore(request.resource.data);
      
      allow delete: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
