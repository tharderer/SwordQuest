rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId} (matches request.auth.uid)
    // Fields:
    //   - uid: string (required) - The unique identifier for the user.
    //   - displayName: string (required) - The user's display name.
    //   - photoURL: string (optional) - The user's profile photo URL.
    //   - email: string (optional) - The user's email address.
    //   - speedVerseProgress: map (optional) - Progress in the Speed Verse game.
    //     - unlockedLevels: list (optional) - List of unlocked level IDs.
    //     - completedRounds: map (optional) - Map of level IDs to the highest completed round.
    //   - createdAt: timestamp (optional) - When the profile was created.
    //   - updatedAt: timestamp (optional) - When the profile was last updated.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'displayName']) &&
             data.uid is string &&
             data.displayName is string && data.displayName.size() > 0 && data.displayName.size() < 100 &&
             (!('email' in data) || (data.email is string && data.email.size() < 255)) &&
             (!('photoURL' in data) || (data.photoURL is string && data.photoURL.size() < 1000));
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }
  }
}
